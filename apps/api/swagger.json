  "info": {
    "title": "API com Swagger",
    "description": "Documentação automática da API com Swagger",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "joao@email.com",
            "description": "Email do usuário a ser cadastrado"
          },
          "password": {
            "type": "string",
            "example": "123456",
            "description": "Senha do usuário a ser cadastrado"
          },
          "role": {
            "type": "string",
            "example": "admin",
            "description": "Papel (role) do usuário a ser cadastrado"
          }
        },
        "required": [
          "email",
          "password",
          "role"
        ]
      },
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Endereço de e-mail do usuário",
            "example": "joao@email.com"
          },
          "password": {
            "type": "string",
            "description": "Senha de acesso do usuário (mínimo 6 caracteres)",
            "example": "senha123",
            "minLength": 6
          },
          "role": {
            "type": "string",
            "description": "Papel do usuário no sistema (ex: ADMIN)",
            "example": "ADMIN"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "CreatePlayerDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Nome completo do jogador",
            "example": "Neymar da Silva"
          },
          "number": {
            "type": "number",
            "description": "Número da camisa do jogador",
            "example": 10,
            "minimum": 1,
            "maximum": 99
          },
          "position": {
            "type": "string",
            "description": "Posição tática do jogador",
            "enum": [
              "GOALKEEPER",
              "DEFENDER",
              "MIDFIELDER",
              "FORWARD"
            ],
            "example": "FORWARD"
          },
          "photoUrl": {
            "type": "string",
            "description": "URL para a foto do jogador",
            "example": "https://exemplo.com/fotos/neymar.jpg"
          }
        },
        "required": [
          "name",
          "number",
          "position"
        ]
      },
      "CreateMatchDto": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "description": "Data e hora da partida no formato ISO 8601",
            "example": "2026-06-22T21:00:00.000Z"
          },
          "opponent": {
            "type": "string",
            "description": "Nome do time adversário",
            "example": "Tabajara FC"
          },
          "location": {
            "type": "string",
            "description": "Local onde a partida será realizada",
            "example": "Estádio Pinheirão"
          },
          "homeScore": {
            "type": "number",
            "description": "Placar do time da casa (La Resenha FC)",
            "example": 3,
            "minimum": 0
          },
          "awayScore": {
            "type": "number",
            "description": "Placar do time visitante (Adversário)",
            "example": 1,
            "minimum": 0
          },
          "championship": {
            "type": "string",
            "description": "Nome do campeonato",
            "example": "Copa UTFR 2026"
          }
        },
        "required": [
          "date",
          "opponent",
          "location",
          "homeScore",
          "awayScore"
        ]
      },
      "CreateNewsDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Título da notícia",
            "example": "La Resenha FC vence o clássico local por 3x1!",
            "maxLength": 200
          },
          "content": {
            "type": "string",
            "description": "Conteúdo principal da notícia",
            "example": "Em um jogo eletrizante na noite de ontem, o time jogou muito bem...",
            "minLength": 10
          },
          "imageUrl": {
            "type": "string",
            "description": "URL da imagem de destaque da notícia",
            "example": "https://exemplo.com/imagens/vitoria.jpg"
          },
          "publishedAt": {
            "type": "string",
            "description": "Data de publicação da notícia (padrão é agora)",
            "example": "2026-06-22T21:00:00.000Z"
          }
        },
        "required": [
          "title",
          "content"
        ]
      },
      "CreateStandingDto": {
        "type": "object",
        "properties": {
          "championship": {
            "type": "string",
            "description": "Nome do campeonato",
            "example": "Liga Amadora de Futebol 2026"
          },
          "position": {
            "type": "number",
            "description": "Posição na tabela de classificação",
            "example": 1
          },
          "points": {
            "type": "number",
            "description": "Pontos ganhos",
            "example": 15
          },
          "played": {
            "type": "number",
            "description": "Partidas jogadas",
            "example": 6
          },
          "won": {
            "type": "number",
            "description": "Vitórias",
            "example": 5
          },
          "drawn": {
            "type": "number",
            "description": "Empates",
            "example": 0
          },
          "lost": {
            "type": "number",
            "description": "Derrotas",
            "example": 1
          },
          "goalsFor": {
            "type": "number",
            "description": "Gols marcados (pró)",
            "example": 18
          },
          "goalsAgainst": {
            "type": "number",
            "description": "Gols sofridos (contra)",
            "example": 4
          }
        },
        "required": [
          "championship",
          "position",
          "points",
          "played",
          "won",
          "drawn",
          "lost",
          "goalsFor",
          "goalsAgainst"
        ]
      },
      "UpdateStandingDto": {
        "type": "object",
        "properties": {
          "championship": {
            "type": "string",
            "description": "Nome do campeonato",
            "example": "Liga Amadora de Futebol 2026"
          },
          "position": {
            "type": "number",
            "description": "Posição na tabela de classificação",
            "example": 1
          },
          "points": {
            "type": "number",
            "description": "Pontos ganhos",
            "example": 15
          },
          "played": {
            "type": "number",
            "description": "Partidas jogadas",
            "example": 6
          },
          "won": {
            "type": "number",
            "description": "Vitórias",
            "example": 5
          },
          "drawn": {
            "type": "number",
            "description": "Empates",
            "example": 0
          },
          "lost": {
            "type": "number",
            "description": "Derrotas",
            "example": 1
          },
          "goalsFor": {
            "type": "number",
            "description": "Gols marcados (pró)",
            "example": 18
          },
          "goalsAgainst": {
            "type": "number",
            "description": "Gols sofridos (contra)",
            "example": 4
          }
        },
        "required": [
          "championship",
          "position",
          "points",
          "played",
          "won",
          "drawn",
          "lost",
          "goalsFor",
          "goalsAgainst"
        ]
      }
    }
  }
}