  "item": [
    {
      "name": "1. Exceção Nativa (NotFoundException)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/players/999",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "3000",
          "path": [
            "players",
            "999"
          ]
        },
        "description": "Tenta buscar um jogador que não existe. Dispara NotFoundException (404), que passa pelo filtro global padrão."
      },
      "response": []
    },
    {
      "name": "2. Exceção Customizada (Regra de Negócio)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Novo Jogador\",\n  \"number\": 1,\n  \"position\": \"Forward\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/players",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "3000",
          "path": [
            "players"
          ]
        },
        "description": "Tenta criar um jogador com a camisa '1', que já pertence ao Carlos Silva. Dispara a exceção de regra de negócio PlayerNumberAlreadyInUseException (422) interceptada pelo novo filtro."
      },
      "response": []
    }
  ]
