  },
  "item": [
    {
      "name": "Teste 1: Criar Jogador (Válido)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Ronaldo\",\n  \"number\": 9,\n  \"position\": \"FORWARD\",\n  \"photoUrl\": \"https://exemplo.com/foto.jpg\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/players",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["players"]
        }
      }
    },
    {
      "name": "Teste 2: Criar Jogador (Inválido)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": 123,\n  \"number\": \"dez\",\n  \"position\": \"ATA\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/players",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["players"]
        }
      }
    },
    {
      "name": "Teste 3: Listar Jogadores com Filtro",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/players?filter=Carlos",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["players"],
          "query": [
            { "key": "filter", "value": "Carlos" }
          ]
        }
      }
    },
    {
      "name": "Teste 4: Buscar Jogador por ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/players/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["players", "1"]
        }
      }
    },
    {
      "name": "Teste 5: Buscar Jogador com ID Inválido",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/players/abc",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["players", "abc"]
        }
      }
    }
  ]
